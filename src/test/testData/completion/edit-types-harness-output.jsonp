{"language": "go", "mode": "FIM", "expected_edit_kind": "Inline", "label": "Go FIM: complete error handling block", "file_path": "handler.go", "cursor_line": 6, "original_content": "", "current_content": "package main\n\nimport \"net/http\"\n\nfunc handler(w http.ResponseWriter, r *http.Request) {\n    if r.Method != \"GET\" {\n\n    }\n    w.Write([]byte(\"OK\"))\n}", "prompt": "<|file_sep|>original/handler.go\n\n<|file_sep|>current/handler.go\npackage main\n\nimport \"net/http\"\n\nfunc handler(w http.ResponseWriter, r *http.Request) {\n    if r.Method != \"GET\" {\n\n    }\n    w.Write([]byte(\"OK\"))\n}\n<|file_sep|>updated/handler.go", "response": "\npackage main\n\nimport \"net/http\"\n\nfunc handler(w http.ResponseWriter, r *http.Request) {\n    if r.Method != \"GET\" {\n        http.Error(w, \"Method not allowed\", http.StatusMethodNotAllowed)\n        return\n    }\n    w.Write([]byte(\"OK\"))\n}\n", "error": null, "elapsed_seconds": 0.382}
{"language": "go", "mode": "NEP", "expected_edit_kind": "Jump", "label": "Go NEP: rename struct field propagates to usage", "file_path": "config.go", "cursor_line": 3, "original_content": "package main\n\ntype Config struct {\n    Host string\n    Port int\n}\n\nfunc (c Config) Address() string {\n    return c.Host + \":\" + string(c.Port)\n}", "current_content": "package main\n\ntype Config struct {\n    Hostname string\n    Port int\n}\n\nfunc (c Config) Address() string {\n    return c.Host + \":\" + string(c.Port)\n}", "prompt": "<|file_sep|>config.go.diff\noriginal:\n    Host string\nupdated:\n    Hostname string\n<|file_sep|>original/config.go\npackage main\n\ntype Config struct {\n    Host string\n    Port int\n}\n\nfunc (c Config) Address() string {\n    return c.Host + \":\" + string(c.Port)\n}\n<|file_sep|>current/config.go\npackage main\n\ntype Config struct {\n    Hostname string\n    Port int\n}\n\nfunc (c Config) Address() string {\n    return c.Host + \":\" + string(c.Port)\n}\n<|file_sep|>updated/config.go", "response": "\npackage main\n\ntype Config struct {\n    Hostname string\n    Port int\n}\n\nfunc (c Config) Address() string {\n    return c.Hostname + \":\" + string(c.Port)\n}\n", "error": null, "elapsed_seconds": 0.264}
{"language": "go", "mode": "NEP", "expected_edit_kind": "Inline", "label": "Go NEP: add context param propagates to function calls", "file_path": "repo.go", "cursor_line": 4, "original_content": "package main\n\nfunc GetUser(id int) (*User, error) {\n    return db.Find(id)\n}\n\nfunc GetUsers() ([]*User, error) {\n    return db.FindAll()\n}", "current_content": "package main\n\nimport \"context\"\n\nfunc GetUser(ctx context.Context, id int) (*User, error) {\n    return db.Find(id)\n}\n\nfunc GetUsers() ([]*User, error) {\n    return db.FindAll()\n}", "prompt": "<|file_sep|>repo.go.diff\noriginal:\nfunc GetUser(id int) (*User, error) {\nupdated:\nfunc GetUser(ctx context.Context, id int) (*User, error) {\n<|file_sep|>original/repo.go\npackage main\n\nfunc GetUser(id int) (*User, error) {\n    return db.Find(id)\n}\n\nfunc GetUsers() ([]*User, error) {\n    return db.FindAll()\n}\n<|file_sep|>current/repo.go\npackage main\n\nimport \"context\"\n\nfunc GetUser(ctx context.Context, id int) (*User, error) {\n    return db.Find(id)\n}\n\nfunc GetUsers() ([]*User, error) {\n    return db.FindAll()\n}\n<|file_sep|>updated/repo.go", "response": "\npackage main\n\nimport \"context\"\n\nfunc GetUser(ctx context.Context, id int) (*User, error) {\n    return db.Find(ctx, id)\n}\n\nfunc GetUsers(ctx context.Context) ([]*User, error) {\n    return db.FindAll(ctx)\n}\n", "error": null, "elapsed_seconds": 0.355}
