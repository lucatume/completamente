{"language": "kotlin", "mode": "NEP", "expected_edit_kind": "Jump", "label": "Kotlin NEP: rename function propagates to call sites", "file_path": "StringUtils.kt", "cursor_line": 0, "original_content": "fun capitalize(s: String): String {\n    return s.replaceFirstChar { it.uppercase() }\n}\n\nfun main() {\n    println(capitalize(\"hello\"))\n    println(capitalize(\"world\"))\n}", "current_content": "fun capitalizeFirst(s: String): String {\n    return s.replaceFirstChar { it.uppercase() }\n}\n\nfun main() {\n    println(capitalize(\"hello\"))\n    println(capitalize(\"world\"))\n}", "prompt": "<|file_sep|>StringUtils.kt.diff\noriginal:\nfun capitalize(s: String): String {\nupdated:\nfun capitalizeFirst(s: String): String {\n<|file_sep|>original/StringUtils.kt\nfun capitalize(s: String): String {\n    return s.replaceFirstChar { it.uppercase() }\n}\n\nfun main() {\n    println(capitalize(\"hello\"))\n    println(capitalize(\"world\"))\n}\n<|file_sep|>current/StringUtils.kt\nfun capitalizeFirst(s: String): String {\n    return s.replaceFirstChar { it.uppercase() }\n}\n\nfun main() {\n    println(capitalize(\"hello\"))\n    println(capitalize(\"world\"))\n}\n<|file_sep|>updated/StringUtils.kt", "response": "\nfun capitalizeFirst(s: String): String {\n    return s.replaceFirstChar { it.uppercase() }\n}\n\nfun capitalize(s: String): String {\n    return s.replaceFirstChar { it.uppercase() } + s.substring(1).lowercase()\n}\n\nfun main() {\n    println(capitalize(\"hello\"))\n    println(capitalize(\"world\"))\n}\n", "error": null, "elapsed_seconds": 0.507}
