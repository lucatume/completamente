{"language": "php", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "PHP NEP mixed: add interface propagates implements", "file_path": "Logger.php", "cursor_line": 6, "original_content": "<?php\n\nclass Logger {\n    public function log(string $msg): void {\n        echo $msg;\n    }\n\n    public function error(string $msg): void {\n        echo \"ERROR: $msg\";\n    }\n}", "current_content": "<?php\n\ninterface LoggerInterface {\n    public function log(string $msg): void;\n}\n\nclass Logger {\n    public function log(string $msg): void {\n        echo $msg;\n    }\n\n    public function error(string $msg): void {\n        echo \"ERROR: $msg\";\n    }\n}", "prompt": "<|file_sep|>Logger.php.diff\noriginal:\n<?php\n\nclass Logger {\nupdated:\n<?php\n\ninterface LoggerInterface {\n    public function log(string $msg): void;\n}\n\nclass Logger {\n<|file_sep|>original/Logger.php\n<?php\n\nclass Logger {\n    public function log(string $msg): void {\n        echo $msg;\n    }\n\n    public function error(string $msg): void {\n        echo \"ERROR: $msg\";\n    }\n}\n<|file_sep|>current/Logger.php\n<?php\n\ninterface LoggerInterface {\n    public function log(string $msg): void;\n}\n\nclass Logger {\n    public function log(string $msg): void {\n        echo $msg;\n    }\n\n    public function error(string $msg): void {\n        echo \"ERROR: $msg\";\n    }\n}\n<|file_sep|>updated/Logger.php", "response": "\n<?php\n\ninterface LoggerInterface {\n    public function log(string $msg): void;\n}\n\nclass Logger implements LoggerInterface {\n    public function log(string $msg): void {\n        echo $msg;\n    }\n\n    public function error(string $msg): void {\n        echo \"ERROR: $msg\";\n    }\n}\n", "error": null, "elapsed_seconds": 0.412}
{"language": "php", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "PHP NEP mixed: rename property propagates to getter and setter", "file_path": "Entity.php", "cursor_line": 3, "original_content": "<?php\n\nclass Entity {\n    private string $name;\n\n    public function getName(): string {\n        return $this->name;\n    }\n\n    public function setName(string $name): void {\n        $this->name = $name;\n    }\n}", "current_content": "<?php\n\nclass Entity {\n    private string $title;\n\n    public function getName(): string {\n        return $this->name;\n    }\n\n    public function setName(string $name): void {\n        $this->name = $name;\n    }\n}", "prompt": "<|file_sep|>Entity.php.diff\noriginal:\n    private string $name;\nupdated:\n    private string $title;\n<|file_sep|>original/Entity.php\n<?php\n\nclass Entity {\n    private string $name;\n\n    public function getName(): string {\n        return $this->name;\n    }\n\n    public function setName(string $name): void {\n        $this->name = $name;\n    }\n}\n<|file_sep|>current/Entity.php\n<?php\n\nclass Entity {\n    private string $title;\n\n    public function getName(): string {\n        return $this->name;\n    }\n\n    public function setName(string $name): void {\n        $this->name = $name;\n    }\n}\n<|file_sep|>updated/Entity.php", "response": "\n<?php\n\nclass Entity {\n    private string $title;\n\n    public function getTitle(): string {\n        return $this->title;\n    }\n\n    public function setTitle(string $title): void {\n        $this->title = $title;\n    }\n}\n", "error": null, "elapsed_seconds": 0.335}
