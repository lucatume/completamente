{"language": "python", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "Python NEP mixed: add type hints to function and update callers", "file_path": "compute.py", "cursor_line": 0, "original_content": "def compute(x, y):\n    return x * y + x\n\na = compute(3, 4)\nb = compute('a', 3)", "current_content": "def compute(x: int, y: int) -> int:\n    return x * y + x\n\na = compute(3, 4)\nb = compute('a', 3)", "prompt": "<|file_sep|>compute.py.diff\noriginal:\ndef compute(x, y):\nupdated:\ndef compute(x: int, y: int) -> int:\n<|file_sep|>original/compute.py\ndef compute(x, y):\n    return x * y + x\n\na = compute(3, 4)\nb = compute('a', 3)\n<|file_sep|>current/compute.py\ndef compute(x: int, y: int) -> int:\n    return x * y + x\n\na = compute(3, 4)\nb = compute('a', 3)\n<|file_sep|>updated/compute.py", "response": "\ndef compute(x: int, y: int) -> int:\n    return x * y + x\n\na = compute(3, 4)\nb = compute(3, 'a')\n", "error": null, "elapsed_seconds": 0.274}
{"language": "python", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "Python NEP mixed: convert function to classmethod", "file_path": "factory.py", "cursor_line": 5, "original_content": "class Widget:\n    def __init__(self, name):\n        self.name = name\n\ndef create_widget(name):\n    return Widget(name)\n\nw = create_widget('btn')", "current_content": "class Widget:\n    def __init__(self, name):\n        self.name = name\n\n    @classmethod\n    def create(cls, name):\n        return cls(name)\n\nw = create_widget('btn')", "prompt": "<|file_sep|>factory.py.diff\noriginal:\ndef create_widget(name):\n    return Widget(name)\nupdated:\n    @classmethod\n    def create(cls, name):\n        return cls(name)\n<|file_sep|>original/factory.py\nclass Widget:\n    def __init__(self, name):\n        self.name = name\n\ndef create_widget(name):\n    return Widget(name)\n\nw = create_widget('btn')\n<|file_sep|>current/factory.py\nclass Widget:\n    def __init__(self, name):\n        self.name = name\n\n    @classmethod\n    def create(cls, name):\n        return cls(name)\n\nw = create_widget('btn')\n<|file_sep|>updated/factory.py", "response": "\nclass Widget:\n    def __init__(self, name):\n        self.name = name\n\n    @classmethod\n    def create(cls, name):\n        return cls(name)\n\nw = Widget.create('btn')\n", "error": null, "elapsed_seconds": 0.284}
