{"language": "ruby", "mode": "NEP", "expected_edit_kind": "Jump", "label": "Ruby NEP: rename class propagates to new and type checks", "file_path": "animal.rb", "cursor_line": 0, "original_content": "class Animal\n  attr_reader :name\n\n  def initialize(name)\n    @name = name\n  end\nend\n\npet = Animal.new('Rex')\nputs pet.is_a?(Animal)", "current_content": "class Pet\n  attr_reader :name\n\n  def initialize(name)\n    @name = name\n  end\nend\n\npet = Animal.new('Rex')\nputs pet.is_a?(Animal)", "prompt": "<|file_sep|>animal.rb.diff\noriginal:\nclass Animal\nupdated:\nclass Pet\n<|file_sep|>original/animal.rb\nclass Animal\n  attr_reader :name\n\n  def initialize(name)\n    @name = name\n  end\nend\n\npet = Animal.new('Rex')\nputs pet.is_a?(Animal)\n<|file_sep|>current/animal.rb\nclass Pet\n  attr_reader :name\n\n  def initialize(name)\n    @name = name\n  end\nend\n\npet = Animal.new('Rex')\nputs pet.is_a?(Animal)\n<|file_sep|>updated/animal.rb", "response": "\nclass Pet\n  attr_reader :name\n\n  def initialize(name)\n    @name = name\n  end\nend\n\npet = Pet.new('Rex')\nputs pet.is_a?(Pet)\n", "error": null, "elapsed_seconds": 0.271}
{"language": "ruby", "mode": "NEP", "expected_edit_kind": "Inline", "label": "Ruby NEP: change symbol key propagates to hash access", "file_path": "options.rb", "cursor_line": 1, "original_content": "def configure(opts = {})\n  host = opts[:host] || 'localhost'\n  port = opts[:port] || 3000\n  timeout = opts[:timeout] || 30\n  [host, port, timeout]\nend\n\nconfigure(host: '0.0.0.0', port: 8080, timeout: 60)", "current_content": "def configure(opts = {})\n  host = opts[:hostname] || 'localhost'\n  port = opts[:port] || 3000\n  timeout = opts[:timeout] || 30\n  [host, port, timeout]\nend\n\nconfigure(host: '0.0.0.0', port: 8080, timeout: 60)", "prompt": "<|file_sep|>options.rb.diff\noriginal:\n  host = opts[:host] || 'localhost'\nupdated:\n  host = opts[:hostname] || 'localhost'\n<|file_sep|>original/options.rb\ndef configure(opts = {})\n  host = opts[:host] || 'localhost'\n  port = opts[:port] || 3000\n  timeout = opts[:timeout] || 30\n  [host, port, timeout]\nend\n\nconfigure(host: '0.0.0.0', port: 8080, timeout: 60)\n<|file_sep|>current/options.rb\ndef configure(opts = {})\n  host = opts[:hostname] || 'localhost'\n  port = opts[:port] || 3000\n  timeout = opts[:timeout] || 30\n  [host, port, timeout]\nend\n\nconfigure(host: '0.0.0.0', port: 8080, timeout: 60)\n<|file_sep|>updated/options.rb", "response": "\ndef configure(opts = {})\n  hostname = opts[:hostname] || 'localhost'\n  port = opts[:port] || 3000\n  timeout = opts[:timeout] || 30\n  [hostname, port, timeout]\nend\n\nconfigure(hostname: '0.0.0.0', port: 8080, timeout: 60)\n", "error": null, "elapsed_seconds": 0.509}
