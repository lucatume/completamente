{"language": "javascript", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "JS NEP mixed: convert function to arrow across file", "file_path": "arrow.js", "cursor_line": 0, "original_content": "const double = function(x) {\n    return x * 2;\n};\n\nconst result = double(5);\nconsole.log(typeof double);", "current_content": "const double = (x) => {\n    return x * 2;\n};\n\nconst result = double(5);\nconsole.log(typeof double);", "prompt": "<|file_sep|>arrow.js.diff\noriginal:\nconst double = function(x) {\nupdated:\nconst double = (x) => {\n<|file_sep|>original/arrow.js\nconst double = function(x) {\n    return x * 2;\n};\n\nconst result = double(5);\nconsole.log(typeof double);\n<|file_sep|>current/arrow.js\nconst double = (x) => {\n    return x * 2;\n};\n\nconst result = double(5);\nconsole.log(typeof double);\n<|file_sep|>updated/arrow.js", "response": "\nconst double = (x) => x * 2;\n\nconst result = double(5);\nconsole.log(typeof double);\n", "error": null, "elapsed_seconds": 0.171}
{"language": "javascript", "mode": "FIM", "expected_edit_kind": "Inline", "label": "JS FIM: complete class constructor", "file_path": "widget.js", "cursor_line": 2, "original_content": "", "current_content": "class Widget {\n    constructor(name, width, height) {\n\n    }\n\n    render() {\n        return `<div>${this.name}</div>`;\n    }\n}", "prompt": "<|file_sep|>original/widget.js\n\n<|file_sep|>current/widget.js\nclass Widget {\n    constructor(name, width, height) {\n\n    }\n\n    render() {\n        return `<div>${this.name}</div>`;\n    }\n}\n<|file_sep|>updated/widget.js", "response": "\nclass Widget {\n    constructor(name, width, height) {\n        this.name = name;\n        this.width = width;\n        this.height = height;\n    }\n\n    render() {\n        return `<div>${this.name}</div>`;\n    }\n}\n", "error": null, "elapsed_seconds": 0.325}
