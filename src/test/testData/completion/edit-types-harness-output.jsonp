{"language": "php", "mode": "NEP", "expected_edit_kind": "Jump", "label": "PHP NEP: rename method propagates to call sites", "file_path": "OrderService.php", "cursor_line": 3, "original_content": "<?php\n\nclass OrderService {\n    public function create(array $data): Order {\n        return Order::fromArray($data);\n    }\n}\n\n$svc = new OrderService();\n$order = $svc->create(['item' => 'Book']);", "current_content": "<?php\n\nclass OrderService {\n    public function createOrder(array $data): Order {\n        return Order::fromArray($data);\n    }\n}\n\n$svc = new OrderService();\n$order = $svc->create(['item' => 'Book']);", "prompt": "<|file_sep|>OrderService.php.diff\noriginal:\n    public function create(array $data): Order {\nupdated:\n    public function createOrder(array $data): Order {\n<|file_sep|>original/OrderService.php\n<?php\n\nclass OrderService {\n    public function create(array $data): Order {\n        return Order::fromArray($data);\n    }\n}\n\n$svc = new OrderService();\n$order = $svc->create(['item' => 'Book']);\n<|file_sep|>current/OrderService.php\n<?php\n\nclass OrderService {\n    public function createOrder(array $data): Order {\n        return Order::fromArray($data);\n    }\n}\n\n$svc = new OrderService();\n$order = $svc->create(['item' => 'Book']);\n<|file_sep|>updated/OrderService.php", "response": "\n<?php\n\nclass OrderService {\n    public function createOrder(array $data): Order {\n        return Order::fromArray($data);\n    }\n}\n\n$svc = new OrderService();\n$order = $svc->createOrder(['item' => 'Book']);\n", "error": null, "elapsed_seconds": 0.344}
{"language": "php", "mode": "NEP", "expected_edit_kind": "Jump", "label": "PHP NEP: add strict types propagates type declarations", "file_path": "functions.php", "cursor_line": 3, "original_content": "<?php\n\nfunction multiply($a, $b) {\n    return $a * $b;\n}\n\nfunction divide($a, $b) {\n    return $a / $b;\n}", "current_content": "<?php\ndeclare(strict_types=1);\n\nfunction multiply(float $a, float $b): float {\n    return $a * $b;\n}\n\nfunction divide($a, $b) {\n    return $a / $b;\n}", "prompt": "<|file_sep|>functions.php.diff\noriginal:\n<?php\n\nfunction multiply($a, $b) {\n    return $a * $b;\n}\nupdated:\n<?php\ndeclare(strict_types=1);\n\nfunction multiply(float $a, float $b): float {\n    return $a * $b;\n}\n<|file_sep|>original/functions.php\n<?php\n\nfunction multiply($a, $b) {\n    return $a * $b;\n}\n\nfunction divide($a, $b) {\n    return $a / $b;\n}\n<|file_sep|>current/functions.php\n<?php\ndeclare(strict_types=1);\n\nfunction multiply(float $a, float $b): float {\n    return $a * $b;\n}\n\nfunction divide($a, $b) {\n    return $a / $b;\n}\n<|file_sep|>updated/functions.php", "response": "\n<?php\ndeclare(strict_types=1);\n\nfunction multiply(float $a, float $b): float {\n    return $a * $b;\n}\n\nfunction divide(float $a, float $b): float {\n    return $a / $b;\n}\n", "error": null, "elapsed_seconds": 0.339}
