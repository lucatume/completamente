{"language": "python", "mode": "NEP", "expected_edit_kind": "Inline", "label": "Python NEP: complete lambda expression", "file_path": "sorter.py", "cursor_line": 1, "original_content": "items = [{'name': 'b'}, {'name': 'a'}]\nsorted_items = sorted(items, key=None)", "current_content": "items = [{'name': 'b'}, {'name': 'a'}]\nsorted_items = sorted(items, key=lambda x:", "prompt": "<|file_sep|>sorter.py.diff\noriginal:\nsorted_items = sorted(items, key=None)\nupdated:\nsorted_items = sorted(items, key=lambda x:\n<|file_sep|>original/sorter.py\nitems = [{'name': 'b'}, {'name': 'a'}]\nsorted_items = sorted(items, key=None)\n<|file_sep|>current/sorter.py\nitems = [{'name': 'b'}, {'name': 'a'}]\nsorted_items = sorted(items, key=lambda x:\n<|file_sep|>updated/sorter.py", "response": "\nitems = [{'name': 'b'}, {'name': 'a'}]\nsorted_items = sorted(items, key=lambda x: x['name'])\n", "error": null, "elapsed_seconds": 0.211}
