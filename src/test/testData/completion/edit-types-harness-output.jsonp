{"language": "ruby", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "Ruby NEP mixed: add attr_writer should propagate to direct assignment", "file_path": "config_obj.rb", "cursor_line": 1, "original_content": "class Config\n  attr_reader :debug\n\n  def initialize\n    @debug = false\n  end\n\n  def enable_debug\n    @debug = true\n  end\nend", "current_content": "class Config\n  attr_accessor :debug\n\n  def initialize\n    @debug = false\n  end\n\n  def enable_debug\n    @debug = true\n  end\nend", "prompt": "<|file_sep|>config_obj.rb.diff\noriginal:\n  attr_reader :debug\nupdated:\n  attr_accessor :debug\n<|file_sep|>original/config_obj.rb\nclass Config\n  attr_reader :debug\n\n  def initialize\n    @debug = false\n  end\n\n  def enable_debug\n    @debug = true\n  end\nend\n<|file_sep|>current/config_obj.rb\nclass Config\n  attr_accessor :debug\n\n  def initialize\n    @debug = false\n  end\n\n  def enable_debug\n    @debug = true\n  end\nend\n<|file_sep|>updated/config_obj.rb", "response": "\nclass Config\n  attr_accessor :debug\n\n  def initialize\n    @debug = false\n  end\n\n  def enable_debug\n    @debug = true\n  end\nend\n", "error": null, "elapsed_seconds": 0.26}
{"language": "ruby", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "Ruby NEP mixed: add rescue block and update return", "file_path": "safe_parse.rb", "cursor_line": 4, "original_content": "def parse_json(str)\n  JSON.parse(str)\nend\n\nresult = parse_json(input)\nputs result.class", "current_content": "def parse_json(str)\n  begin\n    JSON.parse(str)\n  rescue\n\n  end\nend\n\nresult = parse_json(input)\nputs result.class", "prompt": "<|file_sep|>safe_parse.rb.diff\noriginal:\n  JSON.parse(str)\nupdated:\n  begin\n    JSON.parse(str)\n  rescue\n\n  end\n<|file_sep|>original/safe_parse.rb\ndef parse_json(str)\n  JSON.parse(str)\nend\n\nresult = parse_json(input)\nputs result.class\n<|file_sep|>current/safe_parse.rb\ndef parse_json(str)\n  begin\n    JSON.parse(str)\n  rescue\n\n  end\nend\n\nresult = parse_json(input)\nputs result.class\n<|file_sep|>updated/safe_parse.rb", "response": "\ndef parse_json(str)\n  begin\n    JSON.parse(str)\n  rescue JSON::ParserError\n    nil\n  end\nend\n\nresult = parse_json(input)\nputs result.class\n", "error": null, "elapsed_seconds": 0.254}
{"language": "python", "mode": "FIM", "expected_edit_kind": "Inline", "label": "Python FIM: complete try-except block", "file_path": "safe_div.py", "cursor_line": 2, "original_content": "", "current_content": "def safe_divide(a, b):\n    try:\n\n    except ZeroDivisionError:\n        return None", "prompt": "<|file_sep|>original/safe_div.py\n\n<|file_sep|>current/safe_div.py\ndef safe_divide(a, b):\n    try:\n\n    except ZeroDivisionError:\n        return None\n<|file_sep|>updated/safe_div.py", "response": "\ndef safe_divide(a, b):\n    try:\n        return a / b\n    except ZeroDivisionError:\n        return None\n", "error": null, "elapsed_seconds": 0.192}
{"language": "python", "mode": "FIM", "expected_edit_kind": "Inline", "label": "Python FIM: complete dictionary comprehension", "file_path": "invert.py", "cursor_line": 2, "original_content": "", "current_content": "def invert_dict(d):\n    return {\n\n\noriginal = {'a': 1, 'b': 2}\nprint(invert_dict(original))", "prompt": "<|file_sep|>original/invert.py\n\n<|file_sep|>current/invert.py\ndef invert_dict(d):\n    return {\n\n\noriginal = {'a': 1, 'b': 2}\nprint(invert_dict(original))\n<|file_sep|>updated/invert.py", "response": "\ndef invert_dict(d):\n    return {v: k for k, v in d.items()}\n\noriginal = {'a': 1, 'b': 2}\nprint(invert_dict(original))\n", "error": null, "elapsed_seconds": 0.271}
{"language": "python", "mode": "FIM", "expected_edit_kind": "Inline", "label": "Python FIM: complete class with dataclass", "file_path": "point.py", "cursor_line": 4, "original_content": "", "current_content": "from dataclasses import dataclass\n\n@dataclass\nclass Point:\n\n\ndef distance(a: Point, b: Point) -> float:\n    return ((a.x - b.x)**2 + (a.y - b.y)**2)**0.5", "prompt": "<|file_sep|>original/point.py\n\n<|file_sep|>current/point.py\nfrom dataclasses import dataclass\n\n@dataclass\nclass Point:\n\n\ndef distance(a: Point, b: Point) -> float:\n    return ((a.x - b.x)**2 + (a.y - b.y)**2)**0.5\n<|file_sep|>updated/point.py", "response": "\nfrom dataclasses import dataclass\n\n@dataclass\nclass Point:\n    x: float\n    y: float\n\ndef distance(a: Point, b: Point) -> float:\n    return ((a.x - b.x)**2 + (a.y - b.y)**2)**0.5\n", "error": null, "elapsed_seconds": 0.428}
{"language": "python", "mode": "FIM", "expected_edit_kind": "Inline", "label": "Python FIM: complete with-statement body", "file_path": "fileio.py", "cursor_line": 2, "original_content": "", "current_content": "def read_lines(path):\n    with open(path) as f:\n\n\nlines = read_lines('data.txt')\nprint(len(lines))", "prompt": "<|file_sep|>original/fileio.py\n\n<|file_sep|>current/fileio.py\ndef read_lines(path):\n    with open(path) as f:\n\n\nlines = read_lines('data.txt')\nprint(len(lines))\n<|file_sep|>updated/fileio.py", "response": "\nimport os\n\ndef read_lines(path):\n    with open(path) as f:\n        return f.read().splitlines()\n\n\nlines = read_lines('data.txt')\nprint(len(lines))\n", "error": null, "elapsed_seconds": 0.254}
{"language": "python", "mode": "NEP", "expected_edit_kind": "Jump", "label": "Python NEP: rename class propagates to all instantiations", "file_path": "shapes.py", "cursor_line": 0, "original_content": "class Rectangle:\n    def __init__(self, w, h):\n        self.w = w\n        self.h = h\n\n    def area(self):\n        return self.w * self.h\n\nr1 = Rectangle(3, 4)\nr2 = Rectangle(5, 6)\nprint(r1.area(), r2.area())", "current_content": "class Box:\n    def __init__(self, w, h):\n        self.w = w\n        self.h = h\n\n    def area(self):\n        return self.w * self.h\n\nr1 = Rectangle(3, 4)\nr2 = Rectangle(5, 6)\nprint(r1.area(), r2.area())", "prompt": "<|file_sep|>shapes.py.diff\noriginal:\nclass Rectangle:\nupdated:\nclass Box:\n<|file_sep|>original/shapes.py\nclass Rectangle:\n    def __init__(self, w, h):\n        self.w = w\n        self.h = h\n\n    def area(self):\n        return self.w * self.h\n\nr1 = Rectangle(3, 4)\nr2 = Rectangle(5, 6)\nprint(r1.area(), r2.area())\n<|file_sep|>current/shapes.py\nclass Box:\n    def __init__(self, w, h):\n        self.w = w\n        self.h = h\n\n    def area(self):\n        return self.w * self.h\n\nr1 = Rectangle(3, 4)\nr2 = Rectangle(5, 6)\nprint(r1.area(), r2.area())\n<|file_sep|>updated/shapes.py", "response": "\nclass Box:\n    def __init__(self, w, h):\n        self.w = w\n        self.h = h\n\n    def area(self):\n        return self.w * self.h\n\nclass Rectangle(Box):\n    def __init__(self, w, h):\n        super().__init__(w, h)\n\nr1 = Rectangle(3, 4)\nr2 = Rectangle(5, 6)\nprint(r1.area(), r2.area())\n", "error": null, "elapsed_seconds": 0.615}
{"language": "python", "mode": "NEP", "expected_edit_kind": "Inline", "label": "Python NEP: change default parameter propagates to docstring", "file_path": "retry.py", "cursor_line": 0, "original_content": "def retry(func, attempts=3):\n    \"\"\"Retry func up to 3 times.\"\"\"\n    for i in range(attempts):\n        try:\n            return func()\n        except Exception:\n            if i == attempts - 1:\n                raise", "current_content": "def retry(func, attempts=5):\n    \"\"\"Retry func up to 3 times.\"\"\"\n    for i in range(attempts):\n        try:\n            return func()\n        except Exception:\n            if i == attempts - 1:\n                raise", "prompt": "<|file_sep|>retry.py.diff\noriginal:\ndef retry(func, attempts=3):\nupdated:\ndef retry(func, attempts=5):\n<|file_sep|>original/retry.py\ndef retry(func, attempts=3):\n    \"\"\"Retry func up to 3 times.\"\"\"\n    for i in range(attempts):\n        try:\n            return func()\n        except Exception:\n            if i == attempts - 1:\n                raise\n<|file_sep|>current/retry.py\ndef retry(func, attempts=5):\n    \"\"\"Retry func up to 3 times.\"\"\"\n    for i in range(attempts):\n        try:\n            return func()\n        except Exception:\n            if i == attempts - 1:\n                raise\n<|file_sep|>updated/retry.py", "response": "\ndef retry(func, attempts=5):\n    \"\"\"Retry func up to 5 times.\"\"\"\n    for i in range(attempts):\n        try:\n            return func()\n        except Exception:\n            if i == attempts - 1:\n                raise\n", "error": null, "elapsed_seconds": 0.337}
{"language": "python", "mode": "NEP", "expected_edit_kind": "Inline", "label": "Python NEP: add parameter to init propagates to super call", "file_path": "inheritance.py", "cursor_line": 1, "original_content": "class Base:\n    def __init__(self, name):\n        self.name = name\n\nclass Child(Base):\n    def __init__(self, name):\n        super().__init__(name)\n        self.extra = True", "current_content": "class Base:\n    def __init__(self, name, age):\n        self.name = name\n\nclass Child(Base):\n    def __init__(self, name):\n        super().__init__(name)\n        self.extra = True", "prompt": "<|file_sep|>inheritance.py.diff\noriginal:\n    def __init__(self, name):\n        self.name = name\nupdated:\n    def __init__(self, name, age):\n        self.name = name\n<|file_sep|>original/inheritance.py\nclass Base:\n    def __init__(self, name):\n        self.name = name\n\nclass Child(Base):\n    def __init__(self, name):\n        super().__init__(name)\n        self.extra = True\n<|file_sep|>current/inheritance.py\nclass Base:\n    def __init__(self, name, age):\n        self.name = name\n\nclass Child(Base):\n    def __init__(self, name):\n        super().__init__(name)\n        self.extra = True\n<|file_sep|>updated/inheritance.py", "response": "\nclass Base:\n    def __init__(self, name, age):\n        self.name = name\n        self.age = age\n\nclass Child(Base):\n    def __init__(self, name, age):\n        super().__init__(name, age)\n        self.extra = True\n", "error": null, "elapsed_seconds": 0.371}
