{"language": "go", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "Go NEP mixed: change receiver name propagates to method body", "file_path": "server.go", "cursor_line": 6, "original_content": "package main\n\ntype Server struct {\n    Port int\n}\n\nfunc (s Server) Start() {\n    listen(s.Port)\n}\n\nfunc (s Server) Stop() {\n    close(s.Port)\n}", "current_content": "package main\n\ntype Server struct {\n    Port int\n}\n\nfunc (srv Server) Start() {\n    listen(s.Port)\n}\n\nfunc (s Server) Stop() {\n    close(s.Port)\n}", "prompt": "<|file_sep|>server.go.diff\noriginal:\nfunc (s Server) Start() {\nupdated:\nfunc (srv Server) Start() {\n<|file_sep|>original/server.go\npackage main\n\ntype Server struct {\n    Port int\n}\n\nfunc (s Server) Start() {\n    listen(s.Port)\n}\n\nfunc (s Server) Stop() {\n    close(s.Port)\n}\n<|file_sep|>current/server.go\npackage main\n\ntype Server struct {\n    Port int\n}\n\nfunc (srv Server) Start() {\n    listen(s.Port)\n}\n\nfunc (s Server) Stop() {\n    close(s.Port)\n}\n<|file_sep|>updated/server.go", "response": "\npackage main\n\ntype Server struct {\n    Port int\n}\n\nfunc (srv Server) Start() {\n    listen(srv.Port)\n}\n\nfunc (srv Server) Stop() {\n    close(srv.Port)\n}\n", "error": null, "elapsed_seconds": 0.281}
{"language": "ruby", "mode": "FIM", "expected_edit_kind": "Inline", "label": "Ruby FIM: complete module method", "file_path": "validator.rb", "cursor_line": 2, "original_content": "", "current_content": "module Validator\n  def self.valid_email?(email)\n\n  end\n\n  def self.valid_name?(name)\n    name.is_a?(String) && !name.empty?\n  end\nend", "prompt": "<|file_sep|>original/validator.rb\n\n<|file_sep|>current/validator.rb\nmodule Validator\n  def self.valid_email?(email)\n\n  end\n\n  def self.valid_name?(name)\n    name.is_a?(String) && !name.empty?\n  end\nend\n<|file_sep|>updated/validator.rb", "response": "\nmodule Validator\n  def self.valid_email?(email)\n    email.is_a?(String) && email.include?('@')\n  end\n\n  def self.valid_name?(name)\n    name.is_a?(String) && !name.empty?\n  end\nend\n", "error": null, "elapsed_seconds": 0.351}
{"language": "ruby", "mode": "FIM", "expected_edit_kind": "Inline", "label": "Ruby FIM: complete block with do-end", "file_path": "process.rb", "cursor_line": 3, "original_content": "", "current_content": "items = [1, 2, 3, 4, 5]\n\nresults = items.select do |item|\n\nend\n\nputs results", "prompt": "<|file_sep|>original/process.rb\n\n<|file_sep|>current/process.rb\nitems = [1, 2, 3, 4, 5]\n\nresults = items.select do |item|\n\nend\n\nputs results\n<|file_sep|>updated/process.rb", "response": "\nitems = [1, 2, 3, 4, 5]\n\nresults = items.select do |item|\n  item > 2\nend\n\nputs results\n", "error": null, "elapsed_seconds": 0.24}
