{"language": "typescript", "mode": "NEP", "expected_edit_kind": "Jump", "label": "TS NEP: add return type after adding typed parameter", "file_path": "api.ts", "cursor_line": 0, "original_content": "function fetchUser(id) {\n    return fetch(`/api/users/${id}`)\n        .then(res => res.json());\n}", "current_content": "function fetchUser(id: number) {\n    return fetch(`/api/users/${id}`)\n        .then(res => res.json());\n}", "prompt": "<|file_sep|>api.ts.diff\noriginal:\nfunction fetchUser(id) {\nupdated:\nfunction fetchUser(id: number) {\n<|file_sep|>original/api.ts\nfunction fetchUser(id) {\n    return fetch(`/api/users/${id}`)\n        .then(res => res.json());\n}\n<|file_sep|>current/api.ts\nfunction fetchUser(id: number) {\n    return fetch(`/api/users/${id}`)\n        .then(res => res.json());\n}\n<|file_sep|>updated/api.ts", "response": "\nfunction fetchUser(id: number) {\n    return fetch(`/api/users/${id}`)\n        .then(res => res.json());\n}\n", "error": null, "elapsed_seconds": 0.184}
{"language": "typescript", "mode": "NEP", "expected_edit_kind": "Inline", "label": "TS NEP: complete generic type parameter", "file_path": "store.ts", "cursor_line": 0, "original_content": "class Store {\n    private data: any[] = [];\n    add(item: any) { this.data.push(item); }\n    get(index: number): any { return this.data[index]; }\n}", "current_content": "class Store<T> {\n    private data: any[] = [];\n    add(item: any) { this.data.push(item); }\n    get(index: number): any { return this.data[index]; }\n}", "prompt": "<|file_sep|>store.ts.diff\noriginal:\nclass Store {\nupdated:\nclass Store<T> {\n<|file_sep|>original/store.ts\nclass Store {\n    private data: any[] = [];\n    add(item: any) { this.data.push(item); }\n    get(index: number): any { return this.data[index]; }\n}\n<|file_sep|>current/store.ts\nclass Store<T> {\n    private data: any[] = [];\n    add(item: any) { this.data.push(item); }\n    get(index: number): any { return this.data[index]; }\n}\n<|file_sep|>updated/store.ts", "response": "\nclass Store<T> {\n    private data: T[] = [];\n    add(item: T) { this.data.push(item); }\n    get(index: number): T { return this.data[index]; }\n}\n", "error": null, "elapsed_seconds": 0.278}
{"language": "php", "mode": "FIM", "expected_edit_kind": "Inline", "label": "PHP FIM: complete method body", "file_path": "UserController.php", "cursor_line": 4, "original_content": "", "current_content": "<?php\n\nclass UserController {\n    public function index() {\n\n    }\n\n    public function show($id) {\n        return User::find($id);\n    }\n}", "prompt": "<|file_sep|>original/UserController.php\n\n<|file_sep|>current/UserController.php\n<?php\n\nclass UserController {\n    public function index() {\n\n    }\n\n    public function show($id) {\n        return User::find($id);\n    }\n}\n<|file_sep|>updated/UserController.php", "response": "\n<?php\n\nclass UserController extends BaseController {\n    public function index() {\n        return User::all();\n    }\n\n    public function show($id) {\n        return User::find($id);\n    }\n}\n", "error": null, "elapsed_seconds": 0.27}
{"language": "php", "mode": "NEP", "expected_edit_kind": "Jump", "label": "PHP NEP: add type hints after adding return type", "file_path": "Calculator.php", "cursor_line": 3, "original_content": "<?php\n\nclass Calculator {\n    public function add($a, $b) {\n        return $a + $b;\n    }\n\n    public function subtract($a, $b) {\n        return $a - $b;\n    }\n}", "current_content": "<?php\n\nclass Calculator {\n    public function add(int $a, int $b): int {\n        return $a + $b;\n    }\n\n    public function subtract($a, $b) {\n        return $a - $b;\n    }\n}", "prompt": "<|file_sep|>Calculator.php.diff\noriginal:\n    public function add($a, $b) {\nupdated:\n    public function add(int $a, int $b): int {\n<|file_sep|>original/Calculator.php\n<?php\n\nclass Calculator {\n    public function add($a, $b) {\n        return $a + $b;\n    }\n\n    public function subtract($a, $b) {\n        return $a - $b;\n    }\n}\n<|file_sep|>current/Calculator.php\n<?php\n\nclass Calculator {\n    public function add(int $a, int $b): int {\n        return $a + $b;\n    }\n\n    public function subtract($a, $b) {\n        return $a - $b;\n    }\n}\n<|file_sep|>updated/Calculator.php", "response": "\n<?php\n\nclass Calculator {\n    public function add(int $a, int $b): int {\n        return $a + $b;\n    }\n\n    public function subtract(int $a, int $b): int {\n        return $a - $b;\n    }\n}\n", "error": null, "elapsed_seconds": 0.366}
