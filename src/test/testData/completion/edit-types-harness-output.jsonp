{"language": "go", "mode": "FIM", "expected_edit_kind": "Inline", "label": "Go FIM: complete function implementation", "file_path": "main.go", "cursor_line": 5, "original_content": "", "current_content": "package main\n\nimport \"fmt\"\n\nfunc fibonacci(n int) int {\n\n}\n\nfunc main() {\n    fmt.Println(fibonacci(10))\n}", "prompt": "<|file_sep|>original/main.go\n\n<|file_sep|>current/main.go\npackage main\n\nimport \"fmt\"\n\nfunc fibonacci(n int) int {\n\n}\n\nfunc main() {\n    fmt.Println(fibonacci(10))\n}\n<|file_sep|>updated/main.go", "response": "\npackage main\n\nimport \"fmt\"\n\nfunc fibonacci(n int) int {\n    if n <= 1 {\n        return n\n    }\n    return fibonacci(n-1) + fibonacci(n-2)\n}\n\nfunc main() {\n    fmt.Println(fibonacci(10))\n}\n", "error": null, "elapsed_seconds": 0.384}
{"language": "go", "mode": "NEP", "expected_edit_kind": "Inline", "label": "Go NEP: add error return after changing signature", "file_path": "file.go", "cursor_line": 4, "original_content": "package main\n\nimport \"os\"\n\nfunc readFile(path string) string {\n    data, _ := os.ReadFile(path)\n    return string(data)\n}", "current_content": "package main\n\nimport \"os\"\n\nfunc readFile(path string) (string, error) {\n    data, _ := os.ReadFile(path)\n    return string(data)\n}", "prompt": "<|file_sep|>file.go.diff\noriginal:\nfunc readFile(path string) string {\nupdated:\nfunc readFile(path string) (string, error) {\n<|file_sep|>original/file.go\npackage main\n\nimport \"os\"\n\nfunc readFile(path string) string {\n    data, _ := os.ReadFile(path)\n    return string(data)\n}\n<|file_sep|>current/file.go\npackage main\n\nimport \"os\"\n\nfunc readFile(path string) (string, error) {\n    data, _ := os.ReadFile(path)\n    return string(data)\n}\n<|file_sep|>updated/file.go", "response": "\npackage main\n\nimport \"os\"\n\nfunc readFile(path string) (string, error) {\n    data, err := os.ReadFile(path)\n    if err != nil {\n        return \"\", err\n    }\n    return string(data), nil\n}\n", "error": null, "elapsed_seconds": 0.313}
{"language": "go", "mode": "NEP", "expected_edit_kind": "Suppress", "label": "Go NEP: no change needed after comment edit", "file_path": "util.go", "cursor_line": 2, "original_content": "package main\n\n// max returns the larger value\nfunc max(a, b int) int {\n    if a > b {\n        return a\n    }\n    return b\n}", "current_content": "package main\n\n// Max returns the larger of two integers.\nfunc max(a, b int) int {\n    if a > b {\n        return a\n    }\n    return b\n}", "prompt": "<|file_sep|>util.go.diff\noriginal:\n// max returns the larger value\nupdated:\n// Max returns the larger of two integers.\n<|file_sep|>original/util.go\npackage main\n\n// max returns the larger value\nfunc max(a, b int) int {\n    if a > b {\n        return a\n    }\n    return b\n}\n<|file_sep|>current/util.go\npackage main\n\n// Max returns the larger of two integers.\nfunc max(a, b int) int {\n    if a > b {\n        return a\n    }\n    return b\n}\n<|file_sep|>updated/util.go", "response": "\npackage main\n\n// Max returns the larger of two integers.\nfunc Max(a, b int) int {\n    if a > b {\n        return a\n    }\n    return b\n}\n", "error": null, "elapsed_seconds": 0.243}
{"language": "ruby", "mode": "FIM", "expected_edit_kind": "Inline", "label": "Ruby FIM: complete class method", "file_path": "person.rb", "cursor_line": 4, "original_content": "", "current_content": "class Person\n  attr_accessor :name, :age\n\n  def initialize(name, age)\n\n  end\n\n  def greet\n    \"Hello, I'm #{name}\"\n  end\nend", "prompt": "<|file_sep|>original/person.rb\n\n<|file_sep|>current/person.rb\nclass Person\n  attr_accessor :name, :age\n\n  def initialize(name, age)\n\n  end\n\n  def greet\n    \"Hello, I'm #{name}\"\n  end\nend\n<|file_sep|>updated/person.rb", "response": "\nclass Person\n  attr_accessor :name, :age\n\n  def initialize(name, age)\n    @name = name\n    @age = age\n  end\n\n  def greet\n    \"Hello, I'm #{name}\"\n  end\nend\n", "error": null, "elapsed_seconds": 0.324}
{"language": "ruby", "mode": "NEP", "expected_edit_kind": "Jump", "label": "Ruby NEP: update method calls after rename", "file_path": "account.rb", "cursor_line": 5, "original_content": "class Account\n  def initialize(balance)\n    @balance = balance\n  end\n\n  def deposit(amount)\n    @balance += amount\n  end\n\n  def show\n    puts \"Balance: #{@balance}\"\n  end\nend", "current_content": "class Account\n  def initialize(balance)\n    @balance = balance\n  end\n\n  def add_funds(amount)\n    @balance += amount\n  end\n\n  def show\n    puts \"Balance: #{@balance}\"\n  end\nend", "prompt": "<|file_sep|>account.rb.diff\noriginal:\n  def deposit(amount)\nupdated:\n  def add_funds(amount)\n<|file_sep|>original/account.rb\nclass Account\n  def initialize(balance)\n    @balance = balance\n  end\n\n  def deposit(amount)\n    @balance += amount\n  end\n\n  def show\n    puts \"Balance: #{@balance}\"\n  end\nend\n<|file_sep|>current/account.rb\nclass Account\n  def initialize(balance)\n    @balance = balance\n  end\n\n  def add_funds(amount)\n    @balance += amount\n  end\n\n  def show\n    puts \"Balance: #{@balance}\"\n  end\nend\n<|file_sep|>updated/account.rb", "response": "\nclass Account\n  def initialize(balance)\n    @balance = balance\n  end\n\n  def add_funds(amount)\n    @balance += amount\n  end\n\n  def show\n    puts \"Balance: #{@balance}\"\n  end\nend\n", "error": null, "elapsed_seconds": 0.31}
{"language": "python", "mode": "FIM", "expected_edit_kind": "Inline", "label": "Python FIM: complete list comprehension", "file_path": "transform.py", "cursor_line": 2, "original_content": "", "current_content": "def square_evens(numbers):\n    return [\n\n\nresult = square_evens([1, 2, 3, 4, 5])\nprint(result)", "prompt": "<|file_sep|>original/transform.py\n\n<|file_sep|>current/transform.py\ndef square_evens(numbers):\n    return [\n\n\nresult = square_evens([1, 2, 3, 4, 5])\nprint(result)\n<|file_sep|>updated/transform.py", "response": "\ndef square_evens(numbers):\n    return [x**2 for x in numbers if x % 2 == 0]\n\nresult = square_evens([1, 2, 3, 4, 5])\nprint(result)\n", "error": null, "elapsed_seconds": 0.299}
{"language": "python", "mode": "NEP", "expected_edit_kind": "Jump", "label": "Python NEP: propagate rename across file", "file_path": "app.py", "cursor_line": 0, "original_content": "def process(data):\n    cleaned = clean(data)\n    result = transform(cleaned)\n    return result\n\ndef main():\n    raw = load_data()\n    output = process(raw)\n    save(output)", "current_content": "def process_data(data):\n    cleaned = clean(data)\n    result = transform(cleaned)\n    return result\n\ndef main():\n    raw = load_data()\n    output = process(raw)\n    save(output)", "prompt": "<|file_sep|>app.py.diff\noriginal:\ndef process(data):\nupdated:\ndef process_data(data):\n<|file_sep|>original/app.py\ndef process(data):\n    cleaned = clean(data)\n    result = transform(cleaned)\n    return result\n\ndef main():\n    raw = load_data()\n    output = process(raw)\n    save(output)\n<|file_sep|>current/app.py\ndef process_data(data):\n    cleaned = clean(data)\n    result = transform(cleaned)\n    return result\n\ndef main():\n    raw = load_data()\n    output = process(raw)\n    save(output)\n<|file_sep|>updated/app.py", "response": "\ndef process_data(data):\n    cleaned = clean(data)\n    result = transform(cleaned)\n    return result\n\ndef main():\n    raw = load_data()\n    output = process_data(raw)\n    save(output)\n", "error": null, "elapsed_seconds": 0.266}
