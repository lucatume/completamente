{"language": "typescript", "mode": "NEP", "expected_edit_kind": "Suppress", "label": "TS NEP: no change after reordering import", "file_path": "imports.ts", "cursor_line": 0, "original_content": "import { useState, useEffect } from 'react';\n\nfunction App() {\n    const [count, setCount] = useState(0);\n    useEffect(() => {}, []);\n}", "current_content": "import { useEffect, useState } from 'react';\n\nfunction App() {\n    const [count, setCount] = useState(0);\n    useEffect(() => {}, []);\n}", "prompt": "<|file_sep|>imports.ts.diff\noriginal:\nimport { useState, useEffect } from 'react';\nupdated:\nimport { useEffect, useState } from 'react';\n<|file_sep|>original/imports.ts\nimport { useState, useEffect } from 'react';\n\nfunction App() {\n    const [count, setCount] = useState(0);\n    useEffect(() => {}, []);\n}\n<|file_sep|>current/imports.ts\nimport { useEffect, useState } from 'react';\n\nfunction App() {\n    const [count, setCount] = useState(0);\n    useEffect(() => {}, []);\n}\n<|file_sep|>updated/imports.ts", "response": "\nimport { useEffect, useState } from 'react';\n\nfunction App() {\n    const [count, setCount] = useState(0);\n    useEffect(() => {}, [count]);\n}\n", "error": null, "elapsed_seconds": 0.236}
{"language": "typescript", "mode": "NEP", "expected_edit_kind": "Suppress", "label": "TS NEP: no change after adding explicit public modifier", "file_path": "explicit.ts", "cursor_line": 1, "original_content": "class Logger {\n    log(msg: string) {\n        console.log(msg);\n    }\n}", "current_content": "class Logger {\n    public log(msg: string) {\n        console.log(msg);\n    }\n}", "prompt": "<|file_sep|>explicit.ts.diff\noriginal:\n    log(msg: string) {\nupdated:\n    public log(msg: string) {\n<|file_sep|>original/explicit.ts\nclass Logger {\n    log(msg: string) {\n        console.log(msg);\n    }\n}\n<|file_sep|>current/explicit.ts\nclass Logger {\n    public log(msg: string) {\n        console.log(msg);\n    }\n}\n<|file_sep|>updated/explicit.ts", "response": "\nclass Logger {\n    public log(msg: string): void {\n        console.log(msg);\n    }\n}\n", "error": null, "elapsed_seconds": 0.156}
{"language": "typescript", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "TS NEP mixed: make method async propagates await in body", "file_path": "data-service.ts", "cursor_line": 1, "original_content": "class DataService {\n    fetch(url: string): Promise<any> {\n        const res = http.get(url);\n        return res.json();\n    }\n}", "current_content": "class DataService {\n    async fetch(url: string): Promise<any> {\n        const res = http.get(url);\n        return res.json();\n    }\n}", "prompt": "<|file_sep|>data-service.ts.diff\noriginal:\n    fetch(url: string): Promise<any> {\nupdated:\n    async fetch(url: string): Promise<any> {\n<|file_sep|>original/data-service.ts\nclass DataService {\n    fetch(url: string): Promise<any> {\n        const res = http.get(url);\n        return res.json();\n    }\n}\n<|file_sep|>current/data-service.ts\nclass DataService {\n    async fetch(url: string): Promise<any> {\n        const res = http.get(url);\n        return res.json();\n    }\n}\n<|file_sep|>updated/data-service.ts", "response": "\nclass DataService {\n    async fetch(url: string): Promise<any> {\n        const res = await http.get(url);\n        return res.json();\n    }\n}\n", "error": null, "elapsed_seconds": 0.233}
{"language": "typescript", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "TS NEP mixed: change return type propagates to implementation", "file_path": "converter.ts", "cursor_line": 0, "original_content": "function convert(input: string): number {\n    const parsed = parseInt(input, 10);\n    return parsed;\n}\n\nconst val: number = convert('42');", "current_content": "function convert(input: string): number | null {\n    const parsed = parseInt(input, 10);\n    return parsed;\n}\n\nconst val: number = convert('42');", "prompt": "<|file_sep|>converter.ts.diff\noriginal:\nfunction convert(input: string): number {\nupdated:\nfunction convert(input: string): number | null {\n<|file_sep|>original/converter.ts\nfunction convert(input: string): number {\n    const parsed = parseInt(input, 10);\n    return parsed;\n}\n\nconst val: number = convert('42');\n<|file_sep|>current/converter.ts\nfunction convert(input: string): number | null {\n    const parsed = parseInt(input, 10);\n    return parsed;\n}\n\nconst val: number = convert('42');\n<|file_sep|>updated/converter.ts", "response": "\nfunction convert(input: string): number | null {\n    const parsed = parseInt(input, 10);\n    return parsed === NaN ? null : parsed;\n}\n\nconst val: number | null = convert('42');\n", "error": null, "elapsed_seconds": 0.299}
{"language": "php", "mode": "FIM", "expected_edit_kind": "Inline", "label": "PHP FIM: complete constructor with promoted properties", "file_path": "Product.php", "cursor_line": 4, "original_content": "", "current_content": "<?php\n\nclass Product {\n    public function __construct(\n\n    ) {}\n\n    public function getTotal(): float {\n        return $this->price * $this->quantity;\n    }\n}", "prompt": "<|file_sep|>original/Product.php\n\n<|file_sep|>current/Product.php\n<?php\n\nclass Product {\n    public function __construct(\n\n    ) {}\n\n    public function getTotal(): float {\n        return $this->price * $this->quantity;\n    }\n}\n<|file_sep|>updated/Product.php", "response": "\n<?php\n\nclass Product {\n    public function __construct(\n        public float $price,\n        public int $quantity,\n    ) {}\n\n    public function getTotal(): float {\n        return $this->price * $this->quantity;\n    }\n}\n", "error": null, "elapsed_seconds": 0.32}
