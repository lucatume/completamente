{"language": "python", "mode": "NEP", "expected_edit_kind": "Suppress", "label": "Python NEP: no change after whitespace-only edit", "file_path": "clean.py", "cursor_line": 0, "original_content": "x=1\ny = x + 2\nprint(y)", "current_content": "x = 1\ny = x + 2\nprint(y)", "prompt": "<|file_sep|>clean.py.diff\noriginal:\nx=1\nupdated:\nx = 1\n<|file_sep|>original/clean.py\nx=1\ny = x + 2\nprint(y)\n<|file_sep|>current/clean.py\nx = 1\ny = x + 2\nprint(y)\n<|file_sep|>updated/clean.py", "response": "\nx = 1\ny = x + 2\nprint(y)\n", "error": null, "elapsed_seconds": 0.107}
{"language": "javascript", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "JS NEP mixed: add async keyword should propagate await inside", "file_path": "fetcher.js", "cursor_line": 0, "original_content": "function getData(url) {\n    const response = fetch(url);\n    const data = response.json();\n    return data;\n}", "current_content": "async function getData(url) {\n    const response = fetch(url);\n    const data = response.json();\n    return data;\n}", "prompt": "<|file_sep|>fetcher.js.diff\noriginal:\nfunction getData(url) {\nupdated:\nasync function getData(url) {\n<|file_sep|>original/fetcher.js\nfunction getData(url) {\n    const response = fetch(url);\n    const data = response.json();\n    return data;\n}\n<|file_sep|>current/fetcher.js\nasync function getData(url) {\n    const response = fetch(url);\n    const data = response.json();\n    return data;\n}\n<|file_sep|>updated/fetcher.js", "response": "\nasync function getData(url) {\n    const response = await fetch(url);\n    const data = await response.json();\n    return data;\n}\n", "error": null, "elapsed_seconds": 0.175}
{"language": "typescript", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "TS NEP mixed: add type param should propagate to usages", "file_path": "list.ts", "cursor_line": 0, "original_content": "class List {\n    items: any[] = [];\n    add(item: any) { this.items.push(item); }\n    first(): any { return this.items[0]; }\n}", "current_content": "class List<T> {\n    items: any[] = [];\n    add(item: any) { this.items.push(item); }\n    first(): any { return this.items[0]; }\n}", "prompt": "<|file_sep|>list.ts.diff\noriginal:\nclass List {\nupdated:\nclass List<T> {\n<|file_sep|>original/list.ts\nclass List {\n    items: any[] = [];\n    add(item: any) { this.items.push(item); }\n    first(): any { return this.items[0]; }\n}\n<|file_sep|>current/list.ts\nclass List<T> {\n    items: any[] = [];\n    add(item: any) { this.items.push(item); }\n    first(): any { return this.items[0]; }\n}\n<|file_sep|>updated/list.ts", "response": "\nclass List<T> {\n    items: T[] = [];\n    add(item: T) { this.items.push(item); }\n    first(): T { return this.items[0]; }\n}\n", "error": null, "elapsed_seconds": 0.242}
{"language": "python", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "Python NEP mixed: add decorator and update call site", "file_path": "cache.py", "cursor_line": 2, "original_content": "def expensive_calc(n):\n    return sum(range(n))\n\nresult1 = expensive_calc(1000)\nresult2 = expensive_calc(1000)", "current_content": "from functools import lru_cache\n\ndef expensive_calc(n):\n    return sum(range(n))\n\nresult1 = expensive_calc(1000)\nresult2 = expensive_calc(1000)", "prompt": "<|file_sep|>cache.py.diff\noriginal:\ndef expensive_calc(n):\nupdated:\nfrom functools import lru_cache\n\ndef expensive_calc(n):\n<|file_sep|>original/cache.py\ndef expensive_calc(n):\n    return sum(range(n))\n\nresult1 = expensive_calc(1000)\nresult2 = expensive_calc(1000)\n<|file_sep|>current/cache.py\nfrom functools import lru_cache\n\ndef expensive_calc(n):\n    return sum(range(n))\n\nresult1 = expensive_calc(1000)\nresult2 = expensive_calc(1000)\n<|file_sep|>updated/cache.py", "response": "\nfrom functools import lru_cache\n\n@lru_cache(maxsize=1000)\ndef expensive_calc(n):\n    return sum(range(n))\n\nresult1 = expensive_calc(1000)\nresult2 = expensive_calc(1000)\n", "error": null, "elapsed_seconds": 0.322}
{"language": "go", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "Go NEP mixed: change param type propagates to body", "file_path": "parse.go", "cursor_line": 4, "original_content": "package main\n\nimport \"strconv\"\n\nfunc parseAge(s string) int {\n    n, _ := strconv.Atoi(s)\n    return n\n}", "current_content": "package main\n\nimport \"strconv\"\n\nfunc parseAge(s string) (int, error) {\n    n, _ := strconv.Atoi(s)\n    return n\n}", "prompt": "<|file_sep|>parse.go.diff\noriginal:\nfunc parseAge(s string) int {\nupdated:\nfunc parseAge(s string) (int, error) {\n<|file_sep|>original/parse.go\npackage main\n\nimport \"strconv\"\n\nfunc parseAge(s string) int {\n    n, _ := strconv.Atoi(s)\n    return n\n}\n<|file_sep|>current/parse.go\npackage main\n\nimport \"strconv\"\n\nfunc parseAge(s string) (int, error) {\n    n, _ := strconv.Atoi(s)\n    return n\n}\n<|file_sep|>updated/parse.go", "response": "\npackage main\n\nimport \"strconv\"\n\nfunc parseAge(s string) (int, error) {\n    n, err := strconv.ParseInt(s, 10, 0)\n    if err != nil {\n        return 0, err\n    }\n    return int(n), nil\n}\n", "error": null, "elapsed_seconds": 0.381}
{"language": "php", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "PHP NEP mixed: add nullable type propagates null check", "file_path": "service.php", "cursor_line": 3, "original_content": "<?php\n\nclass UserService {\n    public function find(int $id): User {\n        $user = $this->repo->find($id);\n        return $user;\n    }\n}", "current_content": "<?php\n\nclass UserService {\n    public function find(int $id): ?User {\n        $user = $this->repo->find($id);\n        return $user;\n    }\n}", "prompt": "<|file_sep|>service.php.diff\noriginal:\n    public function find(int $id): User {\nupdated:\n    public function find(int $id): ?User {\n<|file_sep|>original/service.php\n<?php\n\nclass UserService {\n    public function find(int $id): User {\n        $user = $this->repo->find($id);\n        return $user;\n    }\n}\n<|file_sep|>current/service.php\n<?php\n\nclass UserService {\n    public function find(int $id): ?User {\n        $user = $this->repo->find($id);\n        return $user;\n    }\n}\n<|file_sep|>updated/service.php", "response": "\n<?php\n\nclass UserService {\n    public function find(int $id): ?User {\n        $user = $this->repo->find($id);\n        return $user ?? null;\n    }\n}\n", "error": null, "elapsed_seconds": 0.272}
{"language": "ruby", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "Ruby NEP mixed: add keyword arg should update call sites", "file_path": "mailer.rb", "cursor_line": 0, "original_content": "def send_email(to, subject, body)\n  # send logic\n  puts \"Sending to #{to}: #{subject}\"\nend\n\nsend_email(\"a@b.com\", \"Hi\", \"Hello\")", "current_content": "def send_email(to, subject, body, cc: nil)\n  # send logic\n  puts \"Sending to #{to}: #{subject}\"\nend\n\nsend_email(\"a@b.com\", \"Hi\", \"Hello\")", "prompt": "<|file_sep|>mailer.rb.diff\noriginal:\ndef send_email(to, subject, body)\nupdated:\ndef send_email(to, subject, body, cc: nil)\n<|file_sep|>original/mailer.rb\ndef send_email(to, subject, body)\n  # send logic\n  puts \"Sending to #{to}: #{subject}\"\nend\n\nsend_email(\"a@b.com\", \"Hi\", \"Hello\")\n<|file_sep|>current/mailer.rb\ndef send_email(to, subject, body, cc: nil)\n  # send logic\n  puts \"Sending to #{to}: #{subject}\"\nend\n\nsend_email(\"a@b.com\", \"Hi\", \"Hello\")\n<|file_sep|>updated/mailer.rb", "response": "\ndef send_email(to, subject, body, cc: nil)\n  # send logic\n  puts \"Sending to #{to}: #{subject}\"\n  puts \"CC: #{cc}\" if cc\nend\n\nsend_email(\"a@b.com\", \"Hi\", \"Hello\")\nsend_email(\"a@b.com\", \"Hi\", \"Hello\", cc: \"c@b.com\")\n", "error": null, "elapsed_seconds": 0.55}
{"language": "javascript", "mode": "FIM", "expected_edit_kind": "Inline", "label": "JS FIM: complete switch statement cases", "file_path": "handler.js", "cursor_line": 3, "original_content": "", "current_content": "function handleAction(action) {\n    switch (action) {\n        case 'start':\n\n    }\n}", "prompt": "<|file_sep|>original/handler.js\n\n<|file_sep|>current/handler.js\nfunction handleAction(action) {\n    switch (action) {\n        case 'start':\n\n    }\n}\n<|file_sep|>updated/handler.js", "response": "\nfunction handleAction(action) {\n    switch (action) {\n        case 'start':\n            return start();\n        case 'stop':\n            return stop();\n        default:\n            return 'Invalid action';\n    }\n}\n\nfunction start() {\n    console.log('Starting...');\n    return 'Started';\n}\n\nfunction stop() {\n    console.log('Stopping...');\n    return 'Stopped';\n}\n", "error": null, "elapsed_seconds": 0.483}
{"language": "javascript", "mode": "FIM", "expected_edit_kind": "Inline", "label": "JS FIM: complete promise chain", "file_path": "api-client.js", "cursor_line": 3, "original_content": "", "current_content": "function loadUsers() {\n    return fetch('/api/users')\n        .then(res =>\n\n}", "prompt": "<|file_sep|>original/api-client.js\n\n<|file_sep|>current/api-client.js\nfunction loadUsers() {\n    return fetch('/api/users')\n        .then(res =>\n\n}\n<|file_sep|>updated/api-client.js", "response": "\nfunction loadUsers() {\n    return fetch('/api/users')\n        .then(res => res.json())\n        .then(users => users);\n}\n", "error": null, "elapsed_seconds": 0.201}
