{"language": "typescript", "mode": "NEP", "expected_edit_kind": "Jump", "label": "TS NEP: rename interface propagates to all usages", "file_path": "types.ts", "cursor_line": 0, "original_content": "interface Config {\n    host: string;\n    port: number;\n}\n\nfunction load(): Config {\n    return { host: 'localhost', port: 3000 };\n}\n\nconst cfg: Config = load();", "current_content": "interface AppConfig {\n    host: string;\n    port: number;\n}\n\nfunction load(): Config {\n    return { host: 'localhost', port: 3000 };\n}\n\nconst cfg: Config = load();", "prompt": "<|file_sep|>types.ts.diff\noriginal:\ninterface Config {\nupdated:\ninterface AppConfig {\n<|file_sep|>original/types.ts\ninterface Config {\n    host: string;\n    port: number;\n}\n\nfunction load(): Config {\n    return { host: 'localhost', port: 3000 };\n}\n\nconst cfg: Config = load();\n<|file_sep|>current/types.ts\ninterface AppConfig {\n    host: string;\n    port: number;\n}\n\nfunction load(): Config {\n    return { host: 'localhost', port: 3000 };\n}\n\nconst cfg: Config = load();\n<|file_sep|>updated/types.ts", "response": "\ninterface AppConfig {\n    host: string;\n    port: number;\n}\n\nfunction load(): AppConfig {\n    return { host: 'localhost', port: 3000 };\n}\n\nconst cfg: AppConfig = load();\n", "error": null, "elapsed_seconds": 0.291}
