{"language": "kotlin", "mode": "NEP", "expected_edit_kind": "Inline+Jump", "label": "Kotlin NEP mixed: make function suspend propagates to call sites", "file_path": "Async.kt", "cursor_line": 0, "original_content": "fun loadData(): String {\n    val data = fetchFromNetwork()\n    return data\n}\n\nfun main() {\n    val result = loadData()\n    println(result)\n}", "current_content": "suspend fun loadData(): String {\n    val data = fetchFromNetwork()\n    return data\n}\n\nfun main() {\n    val result = loadData()\n    println(result)\n}", "prompt": "<|file_sep|>Async.kt.diff\noriginal:\nfun loadData(): String {\nupdated:\nsuspend fun loadData(): String {\n<|file_sep|>original/Async.kt\nfun loadData(): String {\n    val data = fetchFromNetwork()\n    return data\n}\n\nfun main() {\n    val result = loadData()\n    println(result)\n}\n<|file_sep|>current/Async.kt\nsuspend fun loadData(): String {\n    val data = fetchFromNetwork()\n    return data\n}\n\nfun main() {\n    val result = loadData()\n    println(result)\n}\n<|file_sep|>updated/Async.kt", "response": "\nsuspend fun loadData(): String {\n    val data = fetchFromNetwork()\n    return data\n}\n\nsuspend fun main() {\n    val result = loadData()\n    println(result)\n}\n", "error": null, "elapsed_seconds": 0.265}
